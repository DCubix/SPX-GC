# Copy this file to .env and customise before running docker-compose up.

# ── Assets directory ────────────────────────────────────────────────
# Absolute path on the Docker host where SPX assets (graphics, templates,
# media) will be stored.  This directory is bind-mounted into the
# container at /app/ASSETS.
#
# Because it lives on the host filesystem you can expose it through the
# server's existing Samba (or NFS, etc.) without running a separate
# container.
ASSETS_PATH=/opt/spx-gc/ASSETS

# ── Exposing ASSETS via an existing Samba server ────────────────────
# If Samba is already running on this host (port 445), add a share
# definition to your smb.conf that points at ASSETS_PATH above.
#
# Example – append to /etc/samba/smb.conf:
#
#   [spx-assets]
#       path = /opt/spx-gc/ASSETS
#       browsable = yes
#       read only = no
#       guest ok = no
#       valid users = YOUR_SMB_USER
#       create mask = 0664
#       directory mask = 0775
#
# Make sure YOUR_SMB_USER exists in Samba (create with: sudo smbpasswd -a <user>).
# Then reload Samba:
#       sudo smbcontrol all reload-config
#
# Windows clients can map the share as:
#       \\<server-ip>\spx-assets
