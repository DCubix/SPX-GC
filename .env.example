# Copy this file to .env and customise before running docker-compose up.

# Password for the "spxassets" SMB user that Windows machines use to access
# the ASSETS share (\\<host-ip>\assets).
# IMPORTANT: Change this to a strong, unique password before deploying!
SMB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Samba / SMB port ────────────────────────────────────────────────
# Host port that the built-in Samba container listens on.
# Windows clients can ONLY reach SMB shares on port 445, so the default
# is 445.  Change this only if port 445 is already in use on the host
# (e.g. an existing Samba server) and you intend to access the share
# from a non-Windows client that supports alternate ports.
#
# If the host already runs Samba on port 445 and you want Windows
# access, point your existing Samba at the Docker volume instead of
# running the bundled container.  To disable the bundled Samba:
#     docker compose up spx-gc          (start only the app service)
# or remove / comment out the "samba" service in docker-compose.yml.
SMB_PORT=445
